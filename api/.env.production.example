APP_NAME="Be Souhola CRM"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.besouholacrm.net
FRONTEND_URL=https://besouholacrm.net

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# تأكد من مطابقة هذه البيانات مع ما أنشأته في لوحة تحكم Hostinger
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# إعدادات الجلسة والربط (حساسة جداً للـ Subdomains)
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.besouholacrm.net

# السماح للـ Sanctum بالتعامل مع جميع الساب دومينز
SANCTUM_STATEFUL_DOMAINS=besouholacrm.net,api.besouholacrm.net,*.besouholacrm.net

BROADCAST_CONNECTION=reverb

# إعدادات Reverb للـ Real-time
REVERB_APP_ID=1
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="api.besouholacrm.net"
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SCALING_ENABLED=true
REVERB_SCALING_CHANNEL=reverb

# Redis (required for queues, cache, sessions, and Reverb scaling)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# إعدادات البريد الإلكتروني (Hostinger SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=noreply@besouholacrm.net
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@besouholacrm.net"
MAIL_FROM_NAME="${APP_NAME}"
